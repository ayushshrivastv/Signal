{
  "name": "signal",
  "version": "1.0.0",
  "description": "Signal is a ChatGPT-native live World Cup companion powered by TxLINE scores and odds.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "rm -rf dist && tsc --noEmit false",
    "postinstall": "npm run build",
    "start": "node dist/index.js",
    "test": "vitest run tests",
    "txline:devnet:first-call": "tsx scripts/txline-devnet-first-call.ts",
    "txline:devnet:preflight": "tsx scripts/txline-devnet-preflight.ts",
    "txline:devnet:subscribe": "tsx scripts/txline-devnet-subscribe.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.15",
    "@solana/web3.js": "^1.98.4",
    "@types/node": "^26.1.0",
    "axios": "^1.18.1",
    "tsx": "^4.22.5",
    "tweetnacl": "^1.0.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
